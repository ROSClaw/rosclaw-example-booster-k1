+++ b/source/booster_train/booster_train/demo/image_transport.py
@@ -0,0 +1,98 @@
+from __future__ import annotations
+
+import threading
+
+from booster_train.demo.ros_bridge import SpinNode
+from booster_train.demo.runtime import RuntimeSettings
+
+
+class K1CompressedCameraRelay(SpinNode):
+    """Republish Isaac Sim raw camera images as compressed ROS topics."""
+
+    def __init__(self, settings: RuntimeSettings, jpeg_quality: int = 80):
+        super().__init__(settings.node_name("k1_camera_compressor"))
+        self._settings = settings
+        self._jpeg_quality = int(max(1, min(jpeg_quality, 100)))
+        self._publishers = []
+        self._warned_encodings: set[str] = set()
+        self._warned_missing_cv = False
+        self._lock = threading.Lock()
+
+        from sensor_msgs.msg import CompressedImage, Image
+
+        self._compressed_cls = CompressedImage
+        self._subscriptions = []
+        for robot_index in settings.iter_robot_indices():
+            self._publishers.append(
+                self.create_publisher(
+                    CompressedImage,
+                    settings.topic("front_cam/rgb/compressed", robot_index),
+                    10,
+                )
+            )
+            self._subscriptions.append(
+                self.create_subscription(
+                    Image,
+                    settings.topic("front_cam/rgb", robot_index),
+                    lambda msg, idx=robot_index: self._image_cb(msg, idx),
+                    10,
+                )
+            )
+
+    def _image_cb(self, msg, robot_index: int):
+        try:
+            import cv2
+            import numpy as np
+        except Exception as exc:
+            with self._lock:
+                if not self._warned_missing_cv:
+                    self.get_logger().warning(
+                        f"camera compression disabled because OpenCV is unavailable: {exc}"
+                    )
+                    self._warned_missing_cv = True
+            return
+
+        channels = {
+            "rgb8": 3,
+            "bgr8": 3,
+            "rgba8": 4,
+            "bgra8": 4,
+        }.get(msg.encoding)
+        if channels is None:
+            with self._lock:
+                if msg.encoding not in self._warned_encodings:
+                    self.get_logger().warning(
+                        f"unsupported camera encoding '{msg.encoding}', skipping compression"
+                    )
+                    self._warned_encodings.add(msg.encoding)
+            return
+
+        image = np.frombuffer(msg.data, dtype=np.uint8)
+        if image.size != msg.height * msg.width * channels:
+            self.get_logger().warning(
+                "camera image size does not match height/width/encoding, skipping compression"
+            )
+            return
+
+        image = image.reshape((msg.height, msg.width, channels))
+        if msg.encoding == "rgb8":
+            image = cv2.cvtColor(image, cv2.COLOR_RGB2BGR)
+        elif msg.encoding == "rgba8":
+            image = cv2.cvtColor(image, cv2.COLOR_RGBA2BGR)
+        elif msg.encoding == "bgra8":
+            image = cv2.cvtColor(image, cv2.COLOR_BGRA2BGR)
+
+        success, encoded = cv2.imencode(
+            ".jpg",
+            image,
+            [int(cv2.IMWRITE_JPEG_QUALITY), self._jpeg_quality],
+        )
+        if not success:
+            self.get_logger().warning("failed to JPEG-encode camera image")
+            return
+
+        out = self._compressed_cls()
+        out.header = msg.header
+        out.format = "jpeg"
+        out.data = encoded.tobytes()
+        self._publishers[robot_index].publish(out)
