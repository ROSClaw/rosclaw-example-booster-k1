diff --git a/source/booster_train/booster_train/demo/gr00t_backend.py b/source/booster_train/booster_train/demo/gr00t_backend.py
new file mode 100644
index 0000000..36390e5
--- /dev/null
+++ b/source/booster_train/booster_train/demo/gr00t_backend.py
@@ -0,0 +1,150 @@
+from __future__ import annotations
+
+from dataclasses import dataclass
+import os
+from pathlib import Path
+import sys
+
+from booster_train.demo.control import CmdVelControllerRuntime
+
+
+@dataclass(frozen=True)
+class Gr00tBackendStatus:
+    requested_root: str
+    repo_root: str | None
+    active: bool
+    fallback_backend: str
+    reason: str
+
+
+def _resolve_gr00t_root(explicit_root: str | None = None) -> Path | None:
+    root = explicit_root or os.environ.get("GR00T_WBC_ROOT", "")
+    if not root:
+        return None
+    path = Path(root).expanduser().resolve()
+    if not path.exists():
+        return None
+    return path
+
+
+def _inject_repo_root(repo_root: Path) -> None:
+    repo_str = str(repo_root)
+    if repo_str not in sys.path:
+        sys.path.insert(0, repo_str)
+
+
+def _validate_repo(repo_root: Path) -> tuple[bool, str]:
+    expected = [
+        repo_root / "README.md",
+        repo_root / "decoupled_wbc" / "control" / "policy" / "wbc_policy_factory.py",
+        repo_root / "decoupled_wbc" / "control" / "robot_model" / "instantiation" / "g1.py",
+    ]
+    missing = [path for path in expected if not path.exists()]
+    if missing:
+        joined = ", ".join(str(path.relative_to(repo_root)) for path in missing)
+        return False, f"missing expected GR00T files: {joined}"
+
+    _inject_repo_root(repo_root)
+    try:
+        from decoupled_wbc.control.policy import wbc_policy_factory
+        from decoupled_wbc.control.robot_model.instantiation import g1
+    except Exception as exc:
+        return False, f"unable to import GR00T Python modules: {exc}"
+
+    if "g1" not in getattr(wbc_policy_factory, "get_wbc_policy").__code__.co_consts:
+        return False, "GR00T policy factory no longer exposes the expected g1-only entrypoint"
+    if not hasattr(g1, "instantiate_g1_robot_model"):
+        return False, "GR00T robot-model package is missing instantiate_g1_robot_model"
+    return True, "validated"
+
+
+def build_status(explicit_root: str | None = None) -> Gr00tBackendStatus:
+    repo_root = _resolve_gr00t_root(explicit_root)
+    requested_root = explicit_root or os.environ.get("GR00T_WBC_ROOT", "")
+    if repo_root is None:
+        return Gr00tBackendStatus(
+            requested_root=requested_root,
+            repo_root=None,
+            active=False,
+            fallback_backend="vendor_cmd_vel",
+            reason="GR00T repo not found; set --gr00t-root or GR00T_WBC_ROOT",
+        )
+
+    valid, detail = _validate_repo(repo_root)
+    if not valid:
+        return Gr00tBackendStatus(
+            requested_root=requested_root,
+            repo_root=str(repo_root),
+            active=False,
+            fallback_backend="vendor_cmd_vel",
+            reason=detail,
+        )
+
+    # The public GR00T Python stack still hard-codes G1 robot instantiation and policy routing.
+    return Gr00tBackendStatus(
+        requested_root=requested_root,
+        repo_root=str(repo_root),
+        active=False,
+        fallback_backend="vendor_cmd_vel",
+        reason=(
+            "GR00T repo is available, but the shipped Python controller remains G1-specific "
+            "and is not safe to activate on Booster K1 without a dedicated K1 robot-model and "
+            "observation/action adapter"
+        ),
+    )
+
+
+class Gr00tWbcControllerRuntime:
+    """Wrapper that reserves the GR00T backend name while falling back safely."""
+
+    def __init__(self, fallback_runtime: CmdVelControllerRuntime, status: Gr00tBackendStatus):
+        self._fallback_runtime = fallback_runtime
+        self._status = status
+        self._reported = False
+
+    def _report(self):
+        if self._reported:
+            return
+        root_msg = self._status.repo_root or self._status.requested_root or "<unset>"
+        print(
+            "[gr00t] requested controller-backend=gr00t_wbc, "
+            f"repo_root={root_msg}, active={self._status.active}. {self._status.reason}. "
+            f"Falling back to {self._status.fallback_backend}.",
+            flush=True,
+        )
+        self._reported = True
+
+    def start(self):
+        self._report()
+        self._fallback_runtime.start()
+
+    def next_action(self, obs):
+        self._report()
+        return self._fallback_runtime.next_action(obs)
+
+    def shutdown(self):
+        self._fallback_runtime.shutdown()
+
+
+def create_gr00t_controller_runtime(
+    settings,
+    command_buffer,
+    action_dim: int,
+    device,
+    *,
+    fallback_policy=None,
+    gr00t_root: str | None = None,
+    strict: bool = False,
+):
+    status = build_status(gr00t_root)
+    if strict and not status.active:
+        raise RuntimeError(status.reason)
+
+    fallback_runtime = CmdVelControllerRuntime(
+        settings,
+        command_buffer,
+        action_dim,
+        device,
+        policy=fallback_policy,
+    )
+    return Gr00tWbcControllerRuntime(fallback_runtime, status)
