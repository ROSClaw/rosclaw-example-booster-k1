diff --git a/source/booster_train/booster_train/demo/scene_bootstrap.py b/source/booster_train/booster_train/demo/scene_bootstrap.py
new file mode 100644
index 0000000..1a9bbe1
--- /dev/null
+++ b/source/booster_train/booster_train/demo/scene_bootstrap.py
@@ -0,0 +1,96 @@
+from __future__ import annotations
+
+import os
+from typing import Optional
+
+import carb
+import omni.usd
+from pxr import Gf, PhysxSchema, UsdGeom, UsdPhysics
+
+from booster_train.demo.runtime import RuntimeSettings
+
+
+def _find_or_create_physics_scene(stage) -> UsdPhysics.Scene:
+    for prim in stage.Traverse():
+        if prim.IsA(UsdPhysics.Scene):
+            return UsdPhysics.Scene(prim)
+
+    UsdGeom.Xform.Define(stage, "/World")
+    scene = UsdPhysics.Scene.Define(stage, "/World/physicsScene")
+    scene.CreateGravityDirectionAttr().Set(Gf.Vec3f(0.0, 0.0, -1.0))
+    scene.CreateGravityMagnitudeAttr().Set(9.81)
+    return scene
+
+
+def _resolve_scene_reference(scene_usd: str) -> str:
+    if not scene_usd:
+        return ""
+
+    expanded = os.path.expanduser(scene_usd)
+    if os.path.isabs(expanded) and os.path.exists(expanded):
+        return expanded
+
+    if "://" in scene_usd:
+        return scene_usd
+
+    try:
+        from isaacsim.storage.native import get_full_asset_path
+
+        resolved = get_full_asset_path(scene_usd)
+        if resolved:
+            return resolved
+    except Exception as exc:
+        print(f"[scene] asset lookup unavailable for {scene_usd}: {exc}", flush=True)
+
+    print(
+        f"[scene] using unresolved scene reference {scene_usd}; "
+        "set --scene-usd or K1_SCENE_USD to override if this does not resolve at runtime.",
+        flush=True,
+    )
+    return scene_usd
+
+
+def _ensure_scene_reference(stage, scene_prim_path: str, scene_reference: str) -> Optional[str]:
+    if not scene_reference:
+        return None
+
+    scene_xform = UsdGeom.Xform.Define(stage, scene_prim_path)
+    scene_prim = scene_xform.GetPrim()
+
+    if scene_prim.HasAuthoredReferences():
+        return scene_reference
+
+    scene_prim.GetReferences().AddReference(scene_reference)
+    return scene_reference
+
+
+def bootstrap_stage(settings: RuntimeSettings) -> None:
+    stage = omni.usd.get_context().get_stage()
+    if stage is None:
+        raise RuntimeError("USD stage is unavailable; cannot bootstrap the K1 warehouse scene.")
+
+    physics_scene = _find_or_create_physics_scene(stage)
+    physics_prim = physics_scene.GetPrim()
+    physx_scene = PhysxSchema.PhysxSceneAPI.Apply(physics_prim)
+
+    physics_scene.CreateTimeStepsPerSecondAttr().Set(settings.physics_hz)
