--- /dev/null
+++ b/skills/drive-by-velocity/SKILL.md
@@ -0,0 +1,41 @@
+---
+name: drive-by-velocity
+description: Move or turn a ROS2 robot by streaming Twist commands on cmd_vel for a bounded duration.
+---
+
+# Drive By Velocity
+
+## When to Use
+
+Use this skill when the user asks for direct motion such as:
+- "Move forward 3 feet"
+- "Back up 2 feet"
+- "Turn left slowly"
+- "Stop the robot"
+
+## Steps
+
+1. Read odometry before movement with `ros2_subscribe_once` on the robot's odom topic, usually `/odom` or a namespaced topic such as `/k1/odom`.
+2. Use `ros2_cmd_vel` for the requested bounded motion. Do not use a single `ros2_publish` Twist for movement; velocity controllers expect a repeated command stream.
+3. Use the namespaced command topic from the robot context, such as `/k1/cmd_vel`.
+4. For distance requests, convert feet to meters and choose a conservative speed. Example: 3 feet is about 0.91 m, so `linear_x=0.3` for about 3.1 seconds.
+5. Read odometry again after the command and report the measured displacement.
+
+## Example: Move Forward 3 Feet
+
+```
+Tool: ros2_cmd_vel
+Topic: /k1/cmd_vel
+linear_x: 0.3
+linear_y: 0.0
+angular_z: 0.0
+duration_seconds: 3.1
+rate_hz: 10
+stop_at_end: true
+```
+
+## Safety Notes
+
+- Stay within the configured safety limits for linear and angular velocity.
+- Always use `stop_at_end: true` unless the user explicitly asks to keep driving.
+- If odometry does not change, state that the command was sent but motion was not verified.
diff --git a/src/tools/ros2-cmd-vel.ts b/src/tools/ros2-cmd-vel.ts
new file mode 100644
index 0000000..cc609a6
--- /dev/null
+++ b/src/tools/ros2-cmd-vel.ts
@@ -0,0 +1,142 @@
+import { Type } from "@sinclair/typebox";
+import type { OpenClawPluginApi } from "../plugin-api.js";
+import type { RosClawConfig } from "../config.js";
+import { getTransport } from "../service.js";
+
+const TWIST_TYPE = "geometry_msgs/msg/Twist";
+const DEFAULT_RATE_HZ = 10;
+const MIN_RATE_HZ = 2;
+const MAX_RATE_HZ = 30;
+const MAX_DURATION_SECONDS = 30;
+
+function defaultCmdVelTopic(namespace: string): string {
+  const trimmed = namespace.trim().replace(/\/+$/, "");
+  if (!trimmed || trimmed === "/") return "/cmd_vel";
+  return `${trimmed.startsWith("/") ? trimmed : `/${trimmed}`}/cmd_vel`;
+}
+
+function finiteParam(params: Record<string, unknown>, key: string, fallback: number): number {
+  const raw = params[key];
+  const value = raw === undefined ? fallback : Number(raw);
+  if (!Number.isFinite(value)) {
+    throw new Error(`${key} must be a finite number`);
+  }
+  return value;
+}
+
+function sleep(ms: number, signal?: AbortSignal): Promise<void> {
+  if (!signal) {
+    return new Promise((resolve) => setTimeout(resolve, ms));
+  }
+  if (signal.aborted) {
+    return Promise.reject(new Error("ros2_cmd_vel aborted"));
+  }
+
+  return new Promise((resolve, reject) => {
+    const timer = setTimeout(() => {
+      signal.removeEventListener("abort", abort);
+      resolve();
+    }, ms);
+    const abort = () => {
+      clearTimeout(timer);
+      reject(new Error("ros2_cmd_vel aborted"));
+    };
+    signal.addEventListener("abort", abort, { once: true });
+  });
+}
+
+function twist(linearX: number, linearY: number, angularZ: number): Record<string, unknown> {
+  return {
+    linear: { x: linearX, y: linearY, z: 0 },
+    angular: { x: 0, y: 0, z: angularZ },
+  };
+}
+
+/**
+ * Register a sustained velocity-command tool.
+ *
+ * One-shot Twist publishes are easy for an agent to misuse: most mobile bases
+ * and simulated controllers expect a command stream, not a single packet.
+ */
+export function registerCmdVelTool(api: OpenClawPluginApi, config: RosClawConfig): void {
+  api.registerTool({
+    name: "ros2_cmd_vel",
+    label: "ROS2 Velocity Command",
+    description:
+      "Send a sustained geometry_msgs/msg/Twist velocity stream to move the robot. " +
+      "Use this instead of a one-shot ros2_publish for requests like moving forward, backward, turning, or stopping.",
+    parameters: Type.Object({
+      topic: Type.Optional(Type.String({
+        description: `Velocity command topic. Defaults to ${defaultCmdVelTopic(config.robot.namespace)}.`,
+      })),
+      linear_x: Type.Optional(Type.Number({ description: "Forward velocity in m/s. Negative moves backward." })),
+      linear_y: Type.Optional(Type.Number({ description: "Sideways velocity in m/s, if supported." })),
+      angular_z: Type.Optional(Type.Number({ description: "Yaw rate in rad/s. Positive turns left." })),
+      duration_seconds: Type.Number({
+        minimum: 0,
+        maximum: MAX_DURATION_SECONDS,
+        description: "How long to stream the command. Use 2-10 seconds for short smoke tests.",
+      }),
+      rate_hz: Type.Optional(Type.Number({
+        minimum: MIN_RATE_HZ,
+        maximum: MAX_RATE_HZ,
+        description: `Command stream rate. Defaults to ${DEFAULT_RATE_HZ} Hz.`,
+      })),
+      stop_at_end: Type.Optional(Type.Boolean({
+        description: "Publish a zero Twist when the duration ends. Defaults to true.",
+      })),
+    }),
+
+    async execute(_toolCallId, params, signal) {
+      const topic = (params["topic"] as string | undefined) ?? defaultCmdVelTopic(config.robot.namespace);
+      const linearX = finiteParam(params, "linear_x", 0);
+      const linearY = finiteParam(params, "linear_y", 0);
+      const angularZ = finiteParam(params, "angular_z", 0);
+      const durationSeconds = finiteParam(params, "duration_seconds", 0);
+      const requestedRateHz = finiteParam(params, "rate_hz", DEFAULT_RATE_HZ);
+      const rateHz = Math.min(MAX_RATE_HZ, Math.max(MIN_RATE_HZ, requestedRateHz));
+      const stopAtEnd = (params["stop_at_end"] as boolean | undefined) ?? true;
+      const intervalMs = Math.max(1, Math.round(1000 / rateHz));
+      const transport = getTransport();
+      const command = twist(linearX, linearY, angularZ);
+      const startedAt = Date.now();
+      const deadline = startedAt + Math.max(0, durationSeconds * 1000);
+      let publishes = 0;
+
+      do {
+        if (signal?.aborted) throw new Error("ros2_cmd_vel aborted");
+        transport.publish({ topic, type: TWIST_TYPE, msg: command });
+        publishes += 1;
+        const remainingMs = deadline - Date.now();
+        if (remainingMs <= 0) break;
+        await sleep(Math.min(intervalMs, remainingMs), signal);
+      } while (Date.now() < deadline);
+
+      if (stopAtEnd) {
+        const stop = twist(0, 0, 0);
+        for (let i = 0; i < 3; i += 1) {
+          transport.publish({ topic, type: TWIST_TYPE, msg: stop });
+          await sleep(50, signal);
+        }
+      }
+
+      const result = {
+        success: true,
+        topic,
+        type: TWIST_TYPE,
+        linear_x: linearX,
+        linear_y: linearY,
+        angular_z: angularZ,
+        duration_seconds: durationSeconds,
+        rate_hz: rateHz,
+        publishes,
+        stop_at_end: stopAtEnd,
+      };
+
+      return {
+        content: [{ type: "text", text: JSON.stringify(result) }],
+        details: result,
+      };
+    },
+  });
+}
