+/**
+ * Validate sustained velocity command parameters.
+ */
+export function validateCmdVel(
+  params: Record<string, unknown>,
+  safety: SafetyLimits,
+): { block: boolean; blockReason: string } | undefined {
+  const linearX = numberParam(params, "linear_x");
+  const linearY = numberParam(params, "linear_y");
+  const angularZ = numberParam(params, "angular_z");
+  const durationSeconds = numberParam(params, "duration_seconds");
+
+  const speed = Math.sqrt(linearX ** 2 + linearY ** 2);
+  if (speed > safety.maxLinearVelocity) {
+    return {
+      block: true,
+      blockReason: `Linear velocity ${speed.toFixed(2)} m/s exceeds safety limit of ${safety.maxLinearVelocity} m/s`,
+    };
+  }
+
+  if (Math.abs(angularZ) > safety.maxAngularVelocity) {
+    return {
+      block: true,
+      blockReason: `Angular velocity ${Math.abs(angularZ).toFixed(2)} rad/s exceeds safety limit of ${safety.maxAngularVelocity} rad/s`,
+    };
+  }
+
+  if (durationSeconds > 30) {
+    return {
+      block: true,
+      blockReason: "Velocity command duration exceeds the 30 second safety limit",
+    };
+  }
+}
+
+function numberParam(params: Record<string, unknown>, key: string): number {
+  const raw = params[key];
+  if (raw === undefined || raw === null) return 0;
+  const value = Number(raw);
+  return Number.isFinite(value) ? value : 0;
+}
+
 /**
  * Validate workspace limits for navigation action goals.
  */
