+
+
+def test_k1_launch_wrapper_targets_k1_platform():
+    launch_path = (
+        Path(__file__).resolve().parents[1]
+        / "rosclaw_bringup"
+        / "launch"
+        / "k1.launch.py"
+    )
+    contents = launch_path.read_text()
+    assert 'launch_arguments={"platform": "k1"}' in contents
+
+
+def test_k1_platform_configs_use_relative_topics():
+    repo_root = Path(__file__).resolve().parents[1] / "rosclaw_bringup" / "config" / "k1"
+
+    for config_path in [
+        repo_root / "discovery.yaml",
+        repo_root / "perception.yaml",
+        repo_root / "safety_policy.yaml",
+    ]:
+        contents = config_path.read_text()
+        assert "/k1/" not in contents
