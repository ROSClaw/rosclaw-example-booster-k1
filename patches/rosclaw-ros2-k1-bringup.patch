+++ b/rosclaw_bringup/config/k1/perception.yaml
@@ -0,0 +1,12 @@
+# ROSClaw perception config — Booster K1 Isaac Sim
+# The K1 simulator relays the Isaac Sim RGB camera to image_transport compressed.
+
+/**:
+  ros__parameters:
+    camera_topic: "front_cam/rgb/compressed"
+    frame_rate: 1.0
+    gemini_model: "gemini-2.5-flash"
+    api_key_env: "GEMINI_API_KEY"
+    inference_timeout: 20.0
+    max_retries: 2
+    empty_cycles_before_refresh: 4
diff --git a/rosclaw_bringup/config/k1/safety_policy.yaml b/rosclaw_bringup/config/k1/safety_policy.yaml
new file mode 100644
index 0000000..1e0e705
--- /dev/null
+++ b/rosclaw_bringup/config/k1/safety_policy.yaml
@@ -0,0 +1,22 @@
+# ROSClaw safety policy — Booster K1
+# Humanoid robot in Isaac Sim. Keep limits conservative and namespace-safe.
+
+/**:
+  ros__parameters:
+    linear_max: 1.2
+    angular_max: 1.75
+    cmd_vel_topic: "cmd_vel"
+    estop_rate: 10.0
+    allowlisted_topics:
+      - "cmd_vel"
+      - "odom"
+      - "imu"
+      - "joint_states"
+      - "front_cam/rgb/compressed"
+      - "front_cam/camera_info"
+      - "clock"
+      - "tf"
+      - "tf_static"
+      - "navigate_to_pose"
+      - "low_state"
+      - "odometer"
diff --git a/rosclaw_bringup/launch/k1.launch.py b/rosclaw_bringup/launch/k1.launch.py
new file mode 100644
index 0000000..e4072e8
--- /dev/null
+++ b/rosclaw_bringup/launch/k1.launch.py
@@ -0,0 +1,20 @@
+"""Convenience launch: ROSClaw for Booster K1."""
+
+from launch import LaunchDescription
+from launch.actions import IncludeLaunchDescription
+from launch.launch_description_sources import PythonLaunchDescriptionSource
+from ament_index_python.packages import get_package_share_directory
+
+import os
+
+
+def generate_launch_description() -> LaunchDescription:
+    pkg_share = get_package_share_directory("rosclaw_bringup")
+    return LaunchDescription([
+        IncludeLaunchDescription(
+            PythonLaunchDescriptionSource(
+                os.path.join(pkg_share, "launch", "rosclaw.launch.py")
+            ),
+            launch_arguments={"platform": "k1"}.items(),
+        ),
+    ])
