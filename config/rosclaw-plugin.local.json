{
  "transport": {
    "mode": "rosbridge"
  },
  "rosbridge": {
    "url": "ws://localhost:9090",
    "reconnect": true,
    "reconnectInterval": 3000
  },
  "robot": {
    "name": "Isaac Booster K1",
    "namespace": "/k1"
  },
  "safety": {
    "maxLinearVelocity": 0.8,
    "maxAngularVelocity": 0.35,
    "workspaceLimits": {
      "xMin": -10,
      "xMax": 10,
      "yMin": -10,
      "yMax": 10
    }
  }
}
